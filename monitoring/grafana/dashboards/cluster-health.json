{
  "title": "Cluster Health",
  "timezone": "browser",
  "panels": [
    {
      "title": "CPU Usage",
      "type": "timeseries",
      "targets": [{"expr": "sum(rate(container_cpu_usage_seconds_total[5m])) by (pod)"}]
    },
    {
      "title": "Memory Usage",
      "type": "timeseries",
      "targets": [{"expr": "sum(container_memory_usage_bytes) by (pod)"}]
    },
    {
      "title": "Active Pods",
      "type": "stat",
      "targets": [{"expr": "sum(kube_pod_status_phase{phase=\"Running\"})"}]
    }
  ]
}
